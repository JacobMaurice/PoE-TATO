# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# From Grinding Gear Games — obtained by emailing oauth@grindinggear.com
POE_CLIENT_ID=your_client_id_here
POE_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you registered with GGG
POE_REDIRECT_URI=your_redirect_uri_here

# A long random string used to sign state tokens (generate with: openssl rand -hex 32)
STATE_SECRET=replace_with_a_long_random_secret
